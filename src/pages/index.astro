---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import HeroSection from "../components/HeroSection.astro";
import ServiceAreasSection from "../components/ServiceAreasSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import EmergencySection from "../components/EmergencySection.astro";
import ContactSection from "../components/ContactSection.astro";
import ReviewsSection from "../components/ReviewsSection.astro";
import RegionSection from "../components/RegionSection.astro";
import RelatedLinksSection from "../components/RelatedLinksSection.astro";
import SiteFooter from "../components/SiteFooter.astro";

const meta = {
  title: "Schlüsseldienst Oberpfalz – Ihr fairer 24h Schlüsselnotdienst",
  description:
    "Schnelle Türöffnung, transparente Preise und regionale Monteure für die gesamte Oberpfalz. Wir sind Tag und Nacht für Sie erreichbar.",
  canonical: "https://xn--schlsseldienst-oberpfalz-ysc.de/",
  ogImage: "https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=1200&q=80",
};
---

<BaseLayout {...meta}>
  <Header />
  <main>
    <HeroSection />
    <ServiceAreasSection />
    <AboutSection />
    <ServicesSection />
    <EmergencySection />
    <ContactSection />
    <ReviewsSection />
    <RegionSection />
    <RelatedLinksSection />
  </main>
  <SiteFooter />
</BaseLayout>
