---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import SiteFooter from "../components/SiteFooter.astro";

const meta = {
  title: "Datenschutzerklärung – Schlüsseldienst Kölling",
  description:
    "Informationen zur Verarbeitung personenbezogener Daten auf der Website des Schlüsseldienst Kölling gemäß DSGVO.",
  canonical: "https://xn--schlsseldienst-oberpfalz-ysc.de/datenschutz",
};
---

<BaseLayout {...meta}>
  <Header />
