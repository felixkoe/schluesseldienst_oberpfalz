---
import logo from '../assets/logo.png';
---
<header class="site-header supports-[backdrop-filter]:bg-white/80 supports-[backdrop-filter]:backdrop-blur-xl" id="top">
  <div class="top-bar relative overflow-hidden">
    <div class="pointer-events-none absolute inset-y-0 left-0 w-40 bg-gradient-to-r from-amber-300/25 to-transparent"></div>
    <div class="container top-bar__inner">
      <span data-i18n="header.topbar">24h Schlüsselnotdienst Oberpfalz • Sofort zur Stelle</span>
      <div class="top-bar__links">
        <a href="tel:+4917699044112">+49 176 990 44112</a>
        <a href="https://wa.me/4917699044112">WhatsApp</a>
        <div class="lang-switcher">
          <button type="button" class="lang-btn" data-lang="de" title="Deutsch" aria-label="Deutsch">🇩🇪</button>
          <button type="button" class="lang-btn" data-lang="en" title="English" aria-label="English">🇬🇧</button>
        </div>
      </div>
    </div>
  </div>
  <div class="container main-header">
    <a href="/" class="logo">
      <img src={logo.src} alt="Schlüsseldienst Oberpfalz" class="logo__img" />
    </a>
    <nav class="primary-nav" aria-label="Hauptnavigation">
      <input type="checkbox" id="nav-toggle" />
      <label
        for="nav-toggle"
        class="nav-toggle"
        aria-label="Navigation umschalten"
        aria-expanded="false"
      >
        <span></span>
        <span></span>
        <span></span>
      </label>
      <ul class="nav-links" id="primary-navigation">
        <li><a href="/#hero" data-i18n="nav.home">Start</a></li>
        <li><a href="/#leistungen" data-i18n="nav.services">Leistungen</a></li>
        <li><a href="/#servicegebiete" data-i18n="nav.areas">Servicegebiete</a></li>
        <li><a href="/#kontakt" data-i18n="nav.contact">Kontakt</a></li>
      </ul>
    </nav>
    <a
      href="tel:+4917699044112"
      class="header-call"
      data-i18n="header.call"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5Z" clip-rule="evenodd" />
      </svg>
      Jetzt anrufen
    </a>
  </div>
</header>

<style is:global>
  /* ── Top Bar ─────────────────────────────────── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-left: 8px;
  }
  .lang-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 2px 3px;
    border-radius: 4px;
    opacity: 0.45;
    transition: opacity 0.2s;
    line-height: 1;
  }
  .lang-btn--active { opacity: 1; }
  .lang-btn:hover { opacity: 0.8; }
  .lang-btn--active:hover { opacity: 1; }

  /* ── Logo ────────────────────────────────────── */
  .logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .logo:hover { opacity: 0.8; }
  .logo__img {
    height: 48px;
    width: auto;
    display: block;
  }

  /* ── Nav ─────────────────────────────────────── */
  .primary-nav {
    flex: 1 1 auto;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .primary-nav input { display: none; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(120, 113, 108, 0.18);
    background: white;
    transition: background 0.2s, border-color 0.2s;
  }
  .nav-toggle:hover {
    background: #fef3c7;
    border-color: rgba(180, 83, 9, 0.3);
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.15rem;
    list-style: none;
    margin: 0;
    padding: 0.3rem;
    background: rgba(245, 243, 240, 0.7);
    border: 1px solid rgba(120, 113, 108, 0.1);
    border-radius: 999px;
  }
  .nav-links a {
    display: block;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-family: var(--font-nav);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-dark);
    text-decoration: none;
    transition: background 0.18s, color 0.18s;
    white-space: nowrap;
  }
  .nav-links a:hover {
    background: white;
    color: var(--color-primary);
    box-shadow: 0 1px 6px rgba(0,0,0,0.07);
  }

  /* ── CTA Button ──────────────────────────────── */
  .header-call {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.88rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-decoration: none;
    flex-shrink: 0;
    box-shadow: 0 8px 24px -8px rgba(180, 83, 9, 0.55);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .header-call svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .header-call:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 14px 32px -10px rgba(120, 53, 15, 0.65);
  }

  /* ── Mobile ──────────────────────────────────── */
  @media (max-width: 860px) {
    .nav-toggle { display: flex; }

    .nav-links {
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
      border-radius: 16px;
      padding: 0.75rem;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 0;
      right: 0;
      background: white;
      border: 1px solid rgba(120, 113, 108, 0.15);
      box-shadow: 0 16px 40px -12px rgba(0,0,0,0.18);
      z-index: 100;
    }
    .nav-links a {
      border-radius: 10px;
      padding: 0.75rem 1rem;
    }

    .primary-nav input:checked ~ .nav-links {
      display: flex;
    }

    .header-call span { display: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navToggle = document.getElementById('nav-toggle') as HTMLInputElement;
    const navLabel = document.querySelector('label[for="nav-toggle"]');
    const navLinks = document.getElementById('primary-navigation');

    const syncNavState = () => {
      if (navToggle && navLabel) {
        navLabel.setAttribute('aria-expanded', navToggle.checked ? 'true' : 'false');
      }
    };

    if (navToggle && navLabel && navLinks) {
      syncNavState();
      navToggle.addEventListener('change', syncNavState);
      navLinks.addEventListener('click', (event) => {
        if (event.target instanceof HTMLAnchorElement && window.innerWidth <= 860) {
          navToggle.checked = false;
          syncNavState();
        }
      });
    }
  });
</script>
